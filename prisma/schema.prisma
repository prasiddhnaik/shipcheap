generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SavedComparison {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  appType   String
  budget    String
  database  String
  alwaysOn  Boolean
  hasCard   Boolean
  region    String
  riskLevel String

  resultJson Json
}
