generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SavedComparison {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String

  appType   String
  budget    String
  database  String
  alwaysOn  Boolean
  hasCard   Boolean
  region    String
  riskLevel String

  resultJson Json

  @@index([userId])
  @@index([userId, createdAt])
}

model ApiRateLimitBucket {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  route       String
  identifier  String
  windowStart DateTime
  count       Int      @default(0)

  @@unique([route, identifier, windowStart])
  @@index([route, identifier])
  @@index([updatedAt])
}

model PlatformSourceCheck {
  id                  String   @id @default(cuid())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  platformSlug        String
  sourceLabel         String
  sourceUrl           String

  lastCheckedAt       DateTime
  lastChangedAt       DateTime?
  status              String
  httpStatus          Int?
  contentHash         String?
  title               String?
  excerpt             String?
  changedSinceLastRun Boolean  @default(false)
  error               String?
  consecutiveFailures Int      @default(0)

  @@unique([platformSlug, sourceUrl])
  @@index([platformSlug])
  @@index([lastCheckedAt])
  @@index([status])
}

model FreshnessCheckRun {
  id             String    @id @default(cuid())
  createdAt      DateTime  @default(now())
  finishedAt     DateTime?
  status         String
  checkedSources Int       @default(0)
  failedSources  Int       @default(0)
  blockedSources Int       @default(0)
  changedSources Int       @default(0)
  resultJson     Json?
  error          String?
}

model FavoritePlatform {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  platformSlug String
  note         String   @default("")

  @@unique([userId, platformSlug])
  @@index([userId])
  @@index([userId, updatedAt])
}
